engine biome(0.1)
language js

// Collapse single-statement blocks into one-liners.
//
// Mirrors scripts/refactor-one-liners.ts:
//   if (cond) { return x; }      ->  if (cond) return x;
//   if (cond) { stmt; }          ->  if (cond) stmt;
//   else if (cond) { stmt; }     ->  else if (cond) stmt;
//   else { stmt; }               ->  else stmt;
//   for (...) { stmt; }          ->  for (...) stmt;
//   while (cond) { stmt; }       ->  while (cond) stmt;
//   (x) => { return expr; }      ->  (x) => expr;
//
// A block is left untouched when its single statement:
//   - is itself a control-flow statement (if / for / while / switch),
//     matching the original script and avoiding dangling-else hazards;
//   - is a lexical declaration (let / const / class / function), which
//     cannot legally be the sole body of a control-flow statement; or
//   - contains a comment, so no documentation is silently dropped.

or {
    // `if (cond) { stmt; }` and `if (cond) { stmt; } else ...`.
    // The else clause, when present, is preserved verbatim.
    JsIfStatement(test=$cond, consequent=$block, else_clause=$else) as $if where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$if, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $if => `if ($cond) $s $else`
    },

    // `... else { stmt; }` â€” collapse the else branch's block.
    JsIfStatement(test=$cond, consequent=$cons, else_clause=JsElseClause(alternate=$block)) as $if2 where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$if2, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $if2 => `if ($cond) $cons else $s`
    },

    // `for (init; test; update) { stmt; }`
    JsForStatement(initializer=$init, test=$test, update=$update, body=$block) as $for1 where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$for1, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $for1 => `for ($init; $test; $update) $s`
    },

    // `for (init of iter) { stmt; }`
    JsForOfStatement(initializer=$init, expression=$expr, body=$block) as $for2 where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$for2, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $for2 => `for ($init of $expr) $s`
    },

    // `for (init in obj) { stmt; }`
    JsForInStatement(initializer=$init, expression=$expr, body=$block) as $for3 where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$for3, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $for3 => `for ($init in $expr) $s`
    },

    // `while (cond) { stmt; }`
    JsWhileStatement(test=$cond, body=$block) as $while1 where {
        $block <: JsBlockStatement(statements=[$s]),
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        not $s <: or { r"let[^\w][\s\S]*", r"const[^\w][\s\S]*", r"class[^\w][\s\S]*", r"function[^\w][\s\S]*" },
        not $s <: or { JsIfStatement($_, $_), JsForStatement($_, $_, $_, $_), JsForInStatement($_, $_, $_), JsForOfStatement($_, $_, $_), JsWhileStatement($_, $_), JsSwitchStatement($_, $_) },
        register_diagnostic(span=$while1, message="Collapse this single-statement block into a one-liner.", severity="warn", fix_kind="safe"),
        $while1 => `while ($cond) $s`
    },

    // `(params) => { return expr; }`  ->  `(params) => expr`.
    // Only the block body is rewritten, so the arrow's parameters, type
    // parameters and return-type annotation are preserved untouched. This is
    // semantics-preserving: an arrow already captures `this`/`arguments`
    // lexically in either body form.
    //
    // Left untouched when the body:
    //   - has no return argument (`return;`), which cannot become a concise
    //     body without a parse error;
    //   - contains a comment, so no documentation is silently dropped.
    // An object-literal or sequence-expression return is wrapped in parens so
    // it is not re-parsed as a block or a comma expression.
    JsArrowFunctionExpression(body=$block) where {
        $block <: JsFunctionBody(statements=[JsReturnStatement(argument=$ret)]) as $body,
        $ret <: r"[\s\S]+",
        not $block <: or { r"[\s\S]*//[\s\S]*", r"[\s\S]*/\*[\s\S]*" },
        register_diagnostic(span=$body, message="Collapse this single-return arrow function body into a concise one-liner.", severity="warn", fix_kind="safe"),
        if ($ret <: or { JsObjectExpression(), JsSequenceExpression() }) {
            $body => `($ret)`
        } else {
            $body => `$ret`
        }
    }
}
