{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"plugins": ["./oneLiner.grit"],
	"linter": {
		"rules": {
			"preset": "recommended"
		}
	},
	"files": {
		"includes": [
			"**/*.json",
			"**/*.js",
			"**/*.jsx",
			"**/*.ts",
			"**/*.tsx",
			"**/*.mjs",
			"**/*.cjs",
			"!tests",
			"!node_modules",
			"!example.ts"
		]
	}
}
