{
  "name": "biome-one-liner-plugin",
  "version": "1.4.0",
  "description": "Biome plugin that collapses single-statement blocks into one-liners.",
  "license": "ISC",
  "author": "Ivan Stepanian <iv.stpn@gmail.com>",
  "type": "commonjs",
  "keywords": [
    "biome",
    "biome-plugin",
    "gritql",
    "lint",
    "formatter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iv-stpn/biome-one-liner-plugin.git"
  },
  "homepage": "https://github.com/iv-stpn/biome-one-liner-plugin#readme",
  "bugs": {
    "url": "https://github.com/iv-stpn/biome-one-liner-plugin/issues"
  },
  "files": [
    "oneLiner.grit",
    "fixers/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test && node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "fixer:object-defs": "bun run fixers/collapse-object-definitions.ts",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": ">=2.5.4",
    "@changesets/cli": "2.31.0",
    "@types/bun": "1.3.14",
    "@typescript/typescript6": "^6",
    "husky": "9.1.7",
    "typescript": "^7"
  }
}
